generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Perfil {
  USUARIO
  PARCEIRO
  ADMIN
}

// O Prisma chama as tabelas de "model"
model User {
  id        String   @id @default(uuid()) // Gera um ID único automaticamente
  nome      String
  usuario   String   @unique              // O @unique garante que não existam 2 iguais no banco
  email     String   @unique
  senha     String
  perfil    Perfil   @default(USUARIO)
  createdAt DateTime @default(now())      // O banco preenche a data sozinho

  @@map("usuarios") // Opcional: faz a tabela no MySQL se chamar "usuarios" em vez de "User"
}

enum TipoRoteiro {
  A_PE
  ESPORTE_E_AVENTURA
  DE_PRAIAS
  CULTURAL
  RELIGIOSO
  RURAL
  ECOLOGICO
}

model Atividade {
  id          String      @id @default(uuid())
  titulo      String      
  descricao   String      @db.Text 
  local       String      
  latitude    Float?      
  longitude   Float? 
  
  roteiro     TipoRoteiro 

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("atividades")
}