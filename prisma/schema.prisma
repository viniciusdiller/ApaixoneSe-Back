generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Perfil {
  USUARIO
  PARCEIRO
  ADMIN
}

// O Prisma chama as tabelas de "model"
model User {
  id        String   @id @default(uuid()) // Gera um ID único automaticamente
  nome      String
  usuario   String   @unique              // O @unique garante que não existam 2 iguais no banco
  email     String   @unique
  senha     String
  perfil    Perfil   @default(USUARIO)
  createdAt DateTime @default(now())      // O banco preenche a data sozinho

  gastronomias    Gastronomia[]
  hospedagens     Hospedagem[]
  servicosTurista ServicoTurista[]
  planosViagem    PlanoViagem[]
  visitas        Visita[]

  @@map("usuarios")
}



enum TipoRoteiro {
  A_PE
  ESPORTE_E_AVENTURA
  DE_PRAIAS
  CULTURAL
  RELIGIOSO
  RURAL
  ECOLOGICO
}

model Atividade {
  id          String      @id @default(uuid())
  titulo      String      
  descricao   String      @db.Text 
  local       String      
  latitude    Float?      
  longitude   Float? 
  
  roteiro     TipoRoteiro 

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  itensPlanoViagem ItemPlanoViagem[]
  visitas        Visita[]

  @@map("atividades")
}


model Visita {
  id             String       @id @default(uuid())
  
  // Quem visitou?
  usuarioId      String
  usuario        User         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  // O que foi visitado? (Pode ser uma Gastronomia OU uma Atividade)
  gastronomiaId  String?
  gastronomia    Gastronomia? @relation(fields: [gastronomiaId], references: [id], onDelete: Cascade)

  atividadeId    String?
  atividade      Atividade?   @relation(fields: [atividadeId], references: [id], onDelete: Cascade)

  dataVisita     DateTime     @default(now())

  @@map("visitas")
}


enum Mes {
  JANEIRO
  FEVEREIRO
  MARCO
  ABRIL
  MAIO
  JUNHO
  JULHO
  AGOSTO
  SETEMBRO
  OUTUBRO
  NOVEMBRO
  DEZEMBRO
}

model Eventos {
  id          String      @id@default(uuid())
  titulo      String
  descricao   String      @db.Text
  data        DateTime
  local       String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  itensPlanoViagem ItemPlanoViagem[]

  @@map("eventos") 
}

model EventoPrincipal {
  id        String   @id @default(uuid())
  titulo    String
  etapa     String?  
  data      DateTime 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("eventos_principais")
}



enum StatusEstabelecimento {
  PENDENTE
  APROVADO
  REJEITADO
}

model Gastronomia {
  id              String   @id @default(uuid())
  nome            String
  telefone        String
  instagram       String?  // Opcional
  validade         DateTime?
  endereco        String
  especialidade   String?  // Ex: "Frutos do Mar", "Pizzaria"
  
  // Documentos
  cnpj            String   @unique
  responsavelNome String
  responsavelCpf  String
  
  // Arquivos (Físicos no servidor)
  documentoPdfUrl String   // Caminho do PDF salvo no servidor
  logoUrl         String   // Caminho da imagem salva no servidor

  // Controle de Qualidade
  status          StatusEstabelecimento @default(PENDENTE)

  // ==========================================
  // RELACIONAMENTO: QUEM É O DONO? (OWNERSHIP)
  // ==========================================
  usuarioId       String
  usuario         User  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  itensPlanoViagem ItemPlanoViagem[]
  visitas        Visita[]

  @@map("gastronomias")
}

model Hospedagem {
  id               String   @id @default(uuid())
  nome             String
  telefone         String
  tags             Json?
  instagram        String?
  site             String?  
  endereco         String
  textoDiferencial String   @db.Text 
  
  cnpj             String   @unique
  responsavelNome  String
  responsavelCpf   String
  
  documentoPdfUrl  String   
  logoUrl          String   

  status           StatusEstabelecimento @default(PENDENTE)

  usuarioId        String
  usuario          User  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  itensPlanoViagem ItemPlanoViagem[]

  @@map("hospedagens")
}


enum TipoServicoTurista {
  GUIA_TURISMO
  AGENCIA_TURISMO
  ESPORTE_LAZER
  LOCADORA_VEICULOS
}


model ServicoTurista {
  id               String             @id @default(uuid())
  tipo             TipoServicoTurista
  nome             String
  telefone         String
  instagram        String?
  site             String?
  validade         DateTime?
  descricao        String?            @db.Text 
  endereco         String?            
  cnpj             String?
  roteiro          TipoRoteiro?      
  idiomas          String?   
  comprovanteUrl   String?         
  logoUrl          String?   
  fotoUrl          String?   
  status           StatusEstabelecimento @default(PENDENTE)

  // O Dono do Serviço
  usuarioId        String
  usuario          User  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  itensPlanoViagem ItemPlanoViagem[]

  @@map("servicos_turista")
}

model Cat {
  id               String   @id @default(uuid())
  texto            String   @db.Text
  imagensUrl Json?   
  videoUrl   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("cat")
}

model CasaDeCambio {
  id        String @id @default(uuid())
  nome      String
  telefone  String
  endereco  String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SecretariaTurismo {
  id               String                        @id @default(uuid())
  textoExplicativo String                        @db.Text
  videoUrl         String?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  
  turistandos      SecretariaTurismoTuristando[]
  projetos         SecretariaTurismoProjeto[]

  @@map("secretaria_turismo")
}

model SecretariaTurismoTuristando {
  id                  String            @id @default(uuid())
  secretariaTurismoId String
  secretariaTurismo   SecretariaTurismo @relation(fields: [secretariaTurismoId], references: [id], onDelete: Cascade)
  titulo              String
  texto               String            @db.Text
  imagensUrl          Json?             // Array de caminhos das imagens
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("secretaria_turismo_turistando")
}

model SecretariaTurismoProjeto {
  id                  String            @id @default(uuid())
  secretariaTurismoId String
  secretariaTurismo   SecretariaTurismo @relation(fields: [secretariaTurismoId], references: [id], onDelete: Cascade)
  titulo              String
  descricao           String            @db.Text
  imagemUrl           String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("secretaria_turismo_projeto")
}


model PlanoViagem {
  id          String   @id @default(uuid())
  titulo      String
  dataInicio  DateTime
  dataFim     DateTime
  
  // Quem é o dono deste roteiro?
  usuarioId   String
  usuario     User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  // As atividades do roteiro
  itens       ItemPlanoViagem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("planos_viagem")
}

model ItemPlanoViagem {
  id               String   @id @default(uuid())
  dataHoraAgendada DateTime
  anotacao         String?  @db.Text // Ex: "Lembrar de levar toalha"

  // A qual plano este item pertence?
  planoViagemId    String
  planoViagem      PlanoViagem @relation(fields: [planoViagemId], references: [id], onDelete: Cascade)

  // ==========================================
  // RELAÇÕES OPCIONAIS (Polimorfismo)
  // O utilizador preencherá apenas UM destes IDs por cada item criado
  // ==========================================
  gastronomiaId    String?
  gastronomia      Gastronomia? @relation(fields: [gastronomiaId], references: [id], onDelete: SetNull)

  hospedagemId     String?
  hospedagem       Hospedagem?  @relation(fields: [hospedagemId], references: [id], onDelete: SetNull)

  eventoId         String?
  evento           Eventos?     @relation(fields: [eventoId], references: [id], onDelete: SetNull)

  atividadeId      String?
  atividade        Atividade?  @relation(fields: [atividadeId], references: [id], onDelete: SetNull)

  servicoTuristaId String?
  servicoTurista   ServicoTurista? @relation(fields: [servicoTuristaId], references: [id], onDelete: SetNull)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("itens_plano_viagem")
}