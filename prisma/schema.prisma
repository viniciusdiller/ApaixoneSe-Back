generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Perfil {
  USUARIO
  PARCEIRO
  ADMIN
}

// O Prisma chama as tabelas de "model"
model User {
  id        String   @id @default(uuid()) // Gera um ID único automaticamente
  nome      String
  usuario   String   @unique              // O @unique garante que não existam 2 iguais no banco
  email     String   @unique
  senha     String
  perfil    Perfil   @default(USUARIO)
  createdAt DateTime @default(now())      // O banco preenche a data sozinho

  gastronomias Gastronomia[]
  hospedagens  Hospedagem[]
  servicosTurista ServicoTurista[]

  @@map("usuarios")
}



enum TipoRoteiro {
  A_PE
  ESPORTE_E_AVENTURA
  DE_PRAIAS
  CULTURAL
  RELIGIOSO
  RURAL
  ECOLOGICO
}

model Atividade {
  id          String      @id @default(uuid())
  titulo      String      
  descricao   String      @db.Text 
  local       String      
  latitude    Float?      
  longitude   Float? 
  
  roteiro     TipoRoteiro 

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("atividades")
}



enum Mes {
  JANEIRO
  FEVEREIRO
  MARCO
  ABRIL
  MAIO
  JUNHO
  JULHO
  AGOSTO
  SETEMBRO
  OUTUBRO
  NOVEMBRO
  DEZEMBRO
}

model Eventos {
  id          String      @id@default(uuid())
  titulo      String
  descricao   String      @db.Text
  data        DateTime
  local       String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("eventos") 
}



enum StatusEstabelecimento {
  PENDENTE
  APROVADO
  REJEITADO
}

model Gastronomia {
  id              String   @id @default(uuid())
  nome            String
  telefone        String
  instagram       String?  // Opcional
  endereco        String
  especialidade   String?  // Ex: "Frutos do Mar", "Pizzaria"
  
  // Documentos
  cnpj            String   @unique
  responsavelNome String
  responsavelCpf  String
  
  // Arquivos (Físicos no servidor)
  documentoPdfUrl String   // Caminho do PDF salvo no servidor
  logoUrl         String   // Caminho da imagem salva no servidor

  // Controle de Qualidade
  status          StatusEstabelecimento @default(PENDENTE)

  // ==========================================
  // RELACIONAMENTO: QUEM É O DONO? (OWNERSHIP)
  // ==========================================
  usuarioId       String
  usuario         User  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("gastronomias")
}

model Hospedagem {
  id               String   @id @default(uuid())
  nome             String
  telefone         String
  instagram        String?  
  endereco         String
  textoDiferencial String   @db.Text 
  
  cnpj             String   @unique
  responsavelNome  String
  responsavelCpf   String
  
  documentoPdfUrl  String   
  logoUrl          String   

  status           StatusEstabelecimento @default(PENDENTE)

  usuarioId        String
  usuario          User  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("hospedagens")
}


enum TipoServicoTurista {
  GUIA_TURISMO
  AGENCIA_TURISMO
  ESPORTE_LAZER
  LOCADORA_VEICULOS
}


model ServicoTurista {
  id               String             @id @default(uuid())
  tipo             TipoServicoTurista
  nome             String
  telefone         String
  instagram        String?
  descricao        String?            @db.Text 
  endereco         String?            
  cnpj             String?
  roteiro          TipoRoteiro?      
  idiomas          String?            
  logoUrl          String?   
  fotoUrl          String?   
  status           StatusEstabelecimento @default(PENDENTE)

  // O Dono do Serviço
  usuarioId        String
  usuario          User  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("servicos_turista")
}

model Cat {
  id               String   @id @default(uuid())
  texto            String   @db.Text
  arquivoUrl       String   // Ficheiro PDF ou Imagem
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("cat")
}